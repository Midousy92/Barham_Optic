rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction pour vérifier si l'utilisateur est l'administrateur
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "barhamoptic70@gmail.com";
    }

    // Collection Produits : Tout le monde peut lire, SEUL l'admin peut modifier/créer/supprimer
    match /produits/{produitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection Rendez-vous : 
    // - L'admin peut tout faire
    // - Les utilisateurs normaux peuvent créer un rdv, mais pas les lire ni les modifier
    match /rendezvous/{rdvId} {
      // On permet la création (ajout de rdv). On valide optionnellement que la date est présente.
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }
    
    // Collection Utilisateurs : Un utilisateur ne peut lire/modifier que son propre profil
    match /utilisateurs/{userId} {
      // Création autorisée si on est authentifié et que l'ID correspond
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Seul l'admin peut supprimer un utilisateur de la base
      allow delete: if isAdmin();
    }
  }
}
